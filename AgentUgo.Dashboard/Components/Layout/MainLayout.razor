@inherits LayoutComponentBase

<div class="page glass-background">
    <main>
        <header class="top-row px-4 glass-header">
            <h1 class="app-title">Agent Ugo Dashboard</h1>
            <span class="app-subtitle">Real-Time Multi-Agent Orchestration</span>
        </header>

        <section class="content px-4">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
