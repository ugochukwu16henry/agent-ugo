@inherits LayoutComponentBase

<div class="page ugo-main-layout">
    <main>
        <header class="top-row px-4 ugo-main-header">
            <h1 class="ugo-title">Agent Ugo Dashboard</h1>
            <span class="ugo-subtitle">Real-Time Multi-Agent Orchestration</span>
        </header>

        <section class="content px-4 ugo-glass-card">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
