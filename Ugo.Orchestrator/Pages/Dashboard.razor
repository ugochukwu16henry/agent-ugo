@page "/"
@page "/dashboard"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.FluentUI.AspNetCore.Components
@using Ugo.Orchestrator.Hubs
@implements IAsyncDisposable
@inject NavigationManager NavManager

<PageTitle>Agent Ugo | Command Center</PageTitle>

<div class="dashboard-root">
    <FluentHeader Class="dashboard-header">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     HorizontalAlignment="HorizontalAlignment.SpaceBetween" Width="100%">
            <h3 class="dashboard-title">Agent Ugo Orchestrator</h3>
            <FluentBadge Class="header-badge" Appearance="Appearance.Accent">Live Command Center</FluentBadge>
        </FluentStack>
    </FluentHeader>

    <FluentGrid Class="dashboard-grid" Spacing="3" AdaptiveRendering="true">
        <FluentGridItem xs="12" sm="4" md="4">
            <FluentCard Appearance="Appearance.Glass" Class="panel-card">
                <h4 class="panel-title">Human Approval Queue</h4>
                <FluentDivider Role="DividerRole.Presentation" />
                <div class="scroll-region approval-region">
                    @if (PendingApprovals.Count == 0)
                    {
                        <p class="muted-copy">No critical actions waiting for review.</p>
                    }
                    else
                    {
                        @foreach (var request in PendingApprovals.OrderByDescending(r => r.RequestedAt))
                        {
                            <div class="approval-card">
                                <div class="approval-header">
                                    <strong>@request.Action</strong>
                                    <span>@request.RequestedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                </div>
                                <p class="approval-copy">@request.Reason</p>
                                <p class="approval-meta">Payload: @request.Parameters</p>
                                <div class="approval-actions">
                                    <button class="approval-button approve"
                                            @onclick="() => SubmitDecisionAsync(request.Id, true)"
                                            disabled="@IsSubmitting(request.Id)">
                                        Approve
                                    </button>
                                    <button class="approval-button reject"
                                            @onclick="() => SubmitDecisionAsync(request.Id, false)"
                                            disabled="@IsSubmitting(request.Id)">
                                        Reject
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </FluentCard>
        </FluentGridItem>

        <FluentGridItem xs="12" sm="4" md="4">
            <FluentCard Appearance="Appearance.Glass" Class="panel-card">
                <h4 class="panel-title">Director's Ledger</h4>
                <FluentDivider Role="DividerRole.Presentation" />
                <div class="scroll-region">
                    @foreach (var step in PlanSteps)
                    {
                        <FluentCheckbox Label="@step.Task" @bind-Value="step.IsDone" ReadOnly="true" />
                    }
                </div>
            </FluentCard>
        </FluentGridItem>

        <FluentGridItem xs="12" sm="4" md="4">
            <FluentCard Appearance="Appearance.Glass" Class="panel-card">
                <h4 class="panel-title">Parallel Workers (Backend/UI)</h4>
                <FluentDivider Role="DividerRole.Presentation" />

                <h5 class="section-title">Backend</h5>
                <div class="scroll-region workers-region">
                    <FluentStack Orientation="Orientation.Vertical" Spacing="2">
                        @foreach (var msg in LiveThoughts.Where(IsBackendMessage).OrderByDescending(m => m.Timestamp))
                        {
                            <FluentBadge Class="thought-badge" Appearance="@GetAppearance(msg.Status)">
                                @msg.AgentName: @msg.Thought
                            </FluentBadge>
                        }
                    </FluentStack>
                </div>

                <FluentDivider Role="DividerRole.Presentation" />

                <h5 class="section-title">UI</h5>
                <div class="scroll-region workers-region">
                    <FluentStack Orientation="Orientation.Vertical" Spacing="2">
                        @foreach (var msg in LiveThoughts.Where(IsUiMessage).OrderByDescending(m => m.Timestamp))
                        {
                            <FluentBadge Class="thought-badge" Appearance="@GetAppearance(msg.Status)">
                                @msg.AgentName: @msg.Thought
                            </FluentBadge>
                        }
                    </FluentStack>
                </div>
            </FluentCard>
        </FluentGridItem>

        <FluentGridItem xs="12" sm="4" md="4">
            <FluentCard Appearance="Appearance.Glass" Class="panel-card">
                <h4 class="panel-title">Terminal Output</h4>
                <FluentDivider Role="DividerRole.Presentation" />
                <div class="scroll-region terminal-region">
                    <FluentStack Orientation="Orientation.Vertical" Spacing="2">
                        @foreach (var line in BuildTerminalFeed())
                        {
                            <p class="terminal-line">
                                [@line.Timestamp.ToLocalTime().ToString("HH:mm:ss")] @line.Source (@line.Status):
                                @line.Content
                            </p>
                        }
                    </FluentStack>
                </div>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>
</div>

@code {
    private HubConnection? _hubConnection;
    private readonly List<AgentMessage> LiveThoughts = new();
    private readonly List<InternalTraceMessage> InternalTraces = new();
    private readonly List<ApprovalRequestMessage> PendingApprovals = new();
    private readonly HashSet<string> _submittingApprovals = [];

    private readonly List<PlanStep> PlanSteps =
    [
        new("Research and plan implementation", true),
        new("Run Backend and UI in parallel", false),
        new("Review output and finalize", false)
    ];

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/ugohub"))
            .Build();

        _hubConnection.On<AgentMessage>("ReceiveThought", msg =>
        {
            LiveThoughts.Insert(0, msg);
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<InternalTraceMessage>("ReceiveInternalTrace", trace =>
        {
            InternalTraces.Insert(0, trace);
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ApprovalRequestMessage>("ApprovalNeeded", request =>
        {
            PendingApprovals.RemoveAll(existing => existing.Id == request.Id);
            PendingApprovals.Insert(0, request);
            LiveThoughts.Insert(0, new AgentMessage("Director", $"Approval requested for {request.Action}.", "Awaiting Approval",
DateTime.Now));
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ApprovalDecisionMessage>("ApprovalResolved", decision =>
        {
            PendingApprovals.RemoveAll(request => request.Id == decision.ApprovalId);
            _submittingApprovals.Remove(decision.ApprovalId);
            LiveThoughts.Insert(0, new AgentMessage(
                "Director",
                decision.Approved ? "Human approved the critical action." : "Human rejected the critical action.",
                decision.Approved ? "Success" : "Rejected",
                DateTime.Now));
            return InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    private bool IsSubmitting(string approvalId) => _submittingApprovals.Contains(approvalId);

    private async Task SubmitDecisionAsync(string approvalId, bool approved)
    {
        if (_hubConnection is null)
        {
            return;
        }

        _submittingApprovals.Add(approvalId);
        await _hubConnection.InvokeAsync("SubmitApprovalDecision", approvalId, approved);
    }

    private static Appearance GetAppearance(string status) => status switch
    {
        "Working" => Appearance.Accent,
        "Success" => Appearance.Lightweight,
        "Error" => Appearance.Neutral,
        _ => Appearance.Neutral
    };

    private static bool IsBackendMessage(AgentMessage msg)
        => msg.AgentName.Contains("backend", StringComparison.OrdinalIgnoreCase);

    private static bool IsUiMessage(AgentMessage msg)
        => msg.AgentName.Contains("ui", StringComparison.OrdinalIgnoreCase)
           || msg.AgentName.Contains("frontend", StringComparison.OrdinalIgnoreCase);

    private IEnumerable<TerminalLine> BuildTerminalFeed()
        => LiveThoughts
            .Select(msg => new TerminalLine(msg.Timestamp, msg.AgentName, msg.Status, msg.Thought))
            .Concat(InternalTraces.Select(trace => new TerminalLine(
                trace.Timestamp.LocalDateTime,
                $"Trace/{trace.Kind}",
                trace.Status,
                $"{trace.Source}: {trace.Content}")))
            .OrderByDescending(line => line.Timestamp)
            .Take(80);

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private sealed class PlanStep
    {
        public PlanStep(string task, bool isDone)
        {
            Task = task;
            IsDone = isDone;
        }

        public string Task { get; }
        public bool IsDone { get; set; }
    }

    private sealed record TerminalLine(DateTime Timestamp, string Source, string Status, string Content);
}