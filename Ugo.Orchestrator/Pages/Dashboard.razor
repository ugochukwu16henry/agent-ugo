@page "/"
@page "/dashboard"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.FluentUI.AspNetCore.Components
@using Ugo.Orchestrator.Hubs
@using Ugo.Orchestrator.Memory
@implements IAsyncDisposable
@inject NavigationManager NavManager
@inject PreviewService PreviewService
@inject TimeTravelService TimeTravelService
@inject IJSRuntime JSRuntime
@inject IWebHostEnvironment Env

<PageTitle>Agent Ugo | Command Center</PageTitle>

<UgoCommandPalette IsVisible="IsPaletteOpen" IsVisibleChanged="@(v => { IsPaletteOpen = v; StateHasChanged(); })"
                   OnDirectorCommand="HandleDirectorCommandAsync" OnFileOpen="HandleFileOpenAsync" />

<div class="ugo-workbench">
    <div class="activity-bar" aria-label="Activity Bar">
        <button class="activity-btn" title="Chat" type="button"><i
            class="codicon codicon-comment-discussion"></i></button>
            <button class="activity-btn" title="Files" type="button"><i class="codicon codicon-files"></i></button>
            <button class="activity-btn" title="History" type="button"><i class="codicon codicon-history"></i></button>
        </div>

        <FluentSplitter Orientation="Orientation.Horizontal" BarSize="4" Panel1MinSize="220px"
                        Class="workbench-horizontal-splitter">
            <Panel1>
                <aside class="primary-sidebar">
                    <div class="ugo-tab-header">
                        <div class="ugo-tab">AGENT UGO THOUGHT LEDGER</div>
                    </div>
                    <div class="sidebar-scroll">
                        @foreach (var msg in LiveThoughts.Take(30))
                        {
                            <div class="sidebar-item">
                                <div class="sidebar-item-title">@msg.AgentName</div>
                                <div class="sidebar-item-copy">@msg.Thought</div>
                            </div>
                        }
                        @if (LiveThoughts.Count == 0)
                        {
                            <div class="sidebar-item-copy">No thoughts streamed yet.</div>
                        }
                    </div>
                </aside>
            </Panel1>

            <Panel2>
                <FluentSplitter Orientation="Orientation.Vertical" BarSize="4" Panel2MinSize="180px"
                                Class="workbench-vertical-splitter">
                    <Panel1>
                        <main class="editor-view">
                            <div class="editor-header">
                                <img src="/logo.png" alt="Ugo Logo" class="header-logo" />
                                <h3 class="dashboard-title">Agent Ugo Orchestrator</h3>
                                <img src="/ugo-bot-avatar.png" alt="Ugo Bot Avatar" class="header-avatar" />
                                <FluentBadge Class="header-badge" Appearance="Appearance.Accent">Live Command Center
                                </FluentBadge>
                            </div>

                            <div class="editor-content-grid">
                                <section class="panel-card">
                                    <h4 class="panel-title">Live App Preview</h4>
                                    <div class="preview-browser-frame">
                                        @if (!string.IsNullOrWhiteSpace(PreviewService.CurrentPreviewBase64))
                                        {
                                            <img src="data:image/png;base64,@PreviewService.CurrentPreviewBase64"
                                                 class="preview-image" alt="Live preview capture" />
                                        }
                                        else
                                        {
                                            <FluentProgressRing />
                                            <p class="muted-copy">Loading Agent Ugo's UI build preview...</p>
                                        }
                                    </div>
                                </section>

                                <section class="panel-card">
                                    <h4 class="panel-title">History Timeline</h4>
                                    <div class="timeline-toolbar">
                                        <input class="timeline-input" @bind="ManualOverrideInstruction"
                                               placeholder="Manual Override: change the plan and fork a new path" />
                                    </div>
                                    <div class="timeline-list">
                                        @if (History.Count == 0)
                                        {
                                            <p class="muted-copy">No checkpoints recorded yet.</p>
                                        }
                                        else
                                        {
                                            @foreach (var step in History)
                                            {
                                                <div class="timeline-item-card">
                                                    <div class="timeline-label">@step.NodeName</div>
                                                    <div class="timeline-copy">@step.AgentName: @step.LastThought</div>
                                                    <div class="timeline-meta">@step.CreatedAtUtc.ToLocalTime().ToString("HH:mm:ss")
                                                        | Thread @step.ThreadId</div>
                                                        <div class="timeline-actions">
                                                            <button class="approval-button approve"
                                                                    @onclick="() => RewindAsync(step.Id)">Rewind to Here</button>
                                                            <button class="approval-button reject"
                                                                    @onclick="() => ForkAsync(step.Id)">Fork with Override</button>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </section>
                                </div>
                            </main>
                        </Panel1>

                        <Panel2>
                            <section class="ugo-terminal">
                                @if (!BuildTerminalFeed().Any())
                                {
                                    <div>&gt; Agent Ugo Initializing...</div>
                                    <div>&gt; MCP Server Connected to Terminal.</div>
                                }
                                else
                                {
                                    @foreach (var line in BuildTerminalFeed())
                                    {
                                        <div>&gt; [@line.Timestamp.ToLocalTime().ToString("HH:mm:ss")] @line.Source: @line.Content</div>
                                    }
                                }
                            </section>
                        </Panel2>
                    </FluentSplitter>
                </Panel2>
            </FluentSplitter>
        </div>

@code {
    private HubConnection? _hubConnection;
    private bool IsPaletteOpen;
    private DotNetObjectReference<Dashboard>? _dotNetRef;
    private readonly List<AgentMessage> LiveThoughts = new();
    private readonly List<InternalTraceMessage> InternalTraces = new();
    private readonly List<ApprovalRequestMessage> PendingApprovals = new();
    private readonly HashSet<string> _submittingApprovals = [];
    private readonly List<TimeTravelCheckpointView> History = new();
    private string ManualOverrideInstruction = string.Empty;

    private readonly List<PlanStep> PlanSteps =
    [
        new("Research and plan implementation", true),
        new("Run Backend and UI in parallel", false),
        new("Review output and finalize", false)
    ];

    protected override async Task OnInitializedAsync()
    {
        await RefreshHistoryAsync();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/ugohub"))
            .Build();

        _hubConnection.On<AgentMessage>("ReceiveThought", msg =>
        {
            LiveThoughts.Insert(0, msg);
            _ = InvokeAsync(RefreshHistoryAsync);
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<InternalTraceMessage>("ReceiveInternalTrace", trace =>
        {
            InternalTraces.Insert(0, trace);
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<PreviewFrameMessage>("ReceivePreviewFrame", frame =>
        {
            PreviewService.UpdatePreview(frame.Base64Png);
            InternalTraces.Insert(0, new InternalTraceMessage("Preview", "CapturePreview", $"Frame captured from {frame.SourceUrl}",
"Success", frame.CapturedAt));
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ApprovalRequestMessage>("ApprovalNeeded", request =>
        {
            PendingApprovals.RemoveAll(existing => existing.Id == request.Id);
            PendingApprovals.Insert(0, request);
            LiveThoughts.Insert(0, new AgentMessage("Director", $"Approval requested for {request.Action}.", "Awaiting Approval",
DateTime.Now));
            return InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<ApprovalDecisionMessage>("ApprovalResolved", decision =>
        {
            PendingApprovals.RemoveAll(request => request.Id == decision.ApprovalId);
            _submittingApprovals.Remove(decision.ApprovalId);
            LiveThoughts.Insert(0, new AgentMessage("Director", decision.Approved ? "Human approved the critical action." : "Human rejected the critical action.", decision.Approved ? "Success" : "Rejected", DateTime.Now));
            return InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    private bool IsSubmitting(string approvalId) => _submittingApprovals.Contains(approvalId);

    private async Task SubmitDecisionAsync(string approvalId, bool approved)
    {
        if (_hubConnection is null)
        {
            return;
        }

        _submittingApprovals.Add(approvalId);
        await _hubConnection.InvokeAsync("SubmitApprovalDecision", approvalId, approved);
    }

    private async Task RewindAsync(Guid checkpointId)
    {
        var rewound = await TimeTravelService.RewindToStep(checkpointId);
        if (rewound is not null)
        {
            await RefreshHistoryAsync();
            LiveThoughts.Insert(0, new AgentMessage("Director", $"Timeline rewound to {rewound.NodeName}.", "Rewound",
DateTime.Now));
        }
    }

    private async Task ForkAsync(Guid checkpointId)
    {
        if (string.IsNullOrWhiteSpace(ManualOverrideInstruction))
        {
            LiveThoughts.Insert(0, new AgentMessage("Director", "Enter a manual override before forking a checkpoint.", "Needs Input", DateTime.Now));
            return;
        }

        var forked = await TimeTravelService.ModifyAndResume(checkpointId, ManualOverrideInstruction);
        if (forked is not null)
        {
            ManualOverrideInstruction = string.Empty;
            await RefreshHistoryAsync();
            LiveThoughts.Insert(0, new AgentMessage("Director", $"Forked new timeline from {forked.NodeName}.", "Forked",
DateTime.Now));
        }
    }

    private async Task RefreshHistoryAsync()
    {
        History.Clear();
        History.AddRange(await TimeTravelService.GetHistoryAsync());
    }

    private static Appearance GetAppearance(string status) => status switch
    {
        "Working" => Appearance.Accent,
        "Success" => Appearance.Lightweight,
        "Error" => Appearance.Neutral,
        "Cached" => Appearance.Accent,
        _ => Appearance.Neutral
    };

    private static bool IsBackendMessage(AgentMessage msg)
        => msg.AgentName.Contains("backend", StringComparison.OrdinalIgnoreCase);

    private static bool IsUiMessage(AgentMessage msg)
        => msg.AgentName.Contains("ui", StringComparison.OrdinalIgnoreCase)
           || msg.AgentName.Contains("frontend", StringComparison.OrdinalIgnoreCase);

    private IEnumerable<TerminalLine> BuildTerminalFeed()
        => LiveThoughts
            .Select(msg => new TerminalLine(msg.Timestamp, msg.AgentName, msg.Status, msg.Thought))
            .Concat(InternalTraces.Select(trace => new TerminalLine(trace.Timestamp.LocalDateTime, $"Trace/{trace.Kind}",
trace.Status, $"{trace.Source}: {trace.Content}")))
            .OrderByDescending(line => line.Timestamp)
            .Take(80);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("setupPaletteListener", _dotNetRef);
        }
    }

    [JSInvokable]
    public void TogglePalette()
    {
        IsPaletteOpen = !IsPaletteOpen;
        StateHasChanged();
    }

    private void OnPaletteVisibilityChanged(bool visible)
    {
        IsPaletteOpen = visible;
        StateHasChanged();
    }

    private async Task HandleDirectorCommandAsync(string command)
    {
        if (_hubConnection?.State == HubConnectionState.Connected)
        {
            await _hubConnection.InvokeAsync("DispatchDirectorCommand", command);
        }
        InternalTraces.Insert(0, new InternalTraceMessage(
            "DirectorCommand", "CommandPalette", $"Dispatched: {command}", "Sent", DateTimeOffset.Now));
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleFileOpenAsync(string fileName)
    {
        var safeName = Path.GetFileName(fileName);
        var allowedExtensions = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            { ".cs", ".razor", ".json", ".css", ".html", ".md", ".txt", ".js" };

        if (!allowedExtensions.Contains(Path.GetExtension(safeName)))
        {
            InternalTraces.Insert(0, new InternalTraceMessage(
                "FileOpen", "CommandPalette", $"Extension not allowed: {safeName}", "Error", DateTimeOffset.Now));
            await InvokeAsync(StateHasChanged);
            return;
        }

        var fullPath = Path.GetFullPath(Path.Combine(Env.ContentRootPath, safeName));
        if (!fullPath.StartsWith(Env.ContentRootPath, StringComparison.OrdinalIgnoreCase))
        {
            InternalTraces.Insert(0, new InternalTraceMessage(
                "FileOpen", "CommandPalette", "Path traversal rejected.", "Error", DateTimeOffset.Now));
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!File.Exists(fullPath))
        {
            InternalTraces.Insert(0, new InternalTraceMessage(
                "FileOpen", "CommandPalette", $"File not found: {safeName}", "Error", DateTimeOffset.Now));
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var content = await File.ReadAllTextAsync(fullPath);
            var preview = content.Length > 2000 ? content[..2000] + "\n... (truncated)" : content;
            InternalTraces.Insert(0, new InternalTraceMessage(
                "FileOpen", "CommandPalette", $"[{safeName}]\n{preview}", "Success", DateTimeOffset.Now));
        }
        catch (Exception ex)
        {
            InternalTraces.Insert(0, new InternalTraceMessage(
                "FileOpen", "CommandPalette", $"Error reading {safeName}: {ex.Message}", "Error", DateTimeOffset.Now));
        }

        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    private sealed class PlanStep
    {
        public PlanStep(string task, bool isDone)
        {
            Task = task;
            IsDone = isDone;
        }

        public string Task { get; }
        public bool IsDone { get; set; }
    }

    private sealed record TerminalLine(DateTime Timestamp, string Source, string Status, string Content);
}